PORT=58443
TZ=Asia/Shanghai
LABPROBE_IMAGE=onlychallgener/labprobe-hub:latest
HUB_NAME=LabProbe Hub
PRIMARY_ROUTER_NAME=
# 可选：留空使用内置 Lucky 更新仓；私有更新仓才填写。
UPDATE_REPOSITORY_ROOT=
HUB_ADVERTISE_URL=http://192.168.1.20:58443
HUB_HOST_IPV4=192.168.1.20
HUB_HOST_IPV6=
HUB_HOST_MAC=
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=14

# 锐捷/Reyee eWeb：Hub 在局域网内模拟登录并提供白名单路由器管理 API。
# 地址可直接写 192.168.5.1，也可写完整 http://192.168.5.1。
ROUTER_EWEB_URL=http://192.168.5.1
ROUTER_EWEB_PASSWORD=
# 网页允许 600-7200 秒，建议 3600。
ROUTER_SESSION_TIME=3600
ROUTER_VERIFY_TLS=false
# Hub 直连 RPC 作为路由器状态和终端列表主数据源；Relay 只补 IPv6 邻居与 6to6。
ROUTER_RPC_PRIMARY=true
ROUTER_DASHBOARD_POLL_SEC=3
ROUTER_DEVICE_POLL_SEC=5
# 可选：用于加密 config/router_eweb.json；留空时使用 APP_TOKEN 派生。
ROUTER_CONFIG_KEY=

# MQTT实时同步：填写用户自己的Lucky WSS公网地址。
# Lucky反代目标为 Hub宿主机局域网IP:9001，WebSocket默认路径为/mqtt。
MQTT_PUBLIC_URL=wss://mqtt.example.com:27773/mqtt
MQTT_USERNAME=labprobe
MQTT_PASSWORD=请替换为长随机密码
MQTT_TOPIC_PREFIX=labprobe/home
# bridge模式可限制9001只监听本机；Lucky在其他设备时填写Hub局域网IPv4。
MQTT_WS_BIND=0.0.0.0
MQTT_WS_PORT=9001

# APP 使用 APP_TOKEN；LabRelay、Lucky 与 Webhook 使用 HOOK_TOKEN。
APP_TOKEN=change-app-token
HOOK_TOKEN=change-hook-token

# SQLite 增量历史有界保留，避免高频状态长期撑大数据库。
REVISION_MAX_ROWS=5000
REVISION_MAX_AGE_DAYS=7
REVISION_PRUNE_INTERVAL_SEC=300
